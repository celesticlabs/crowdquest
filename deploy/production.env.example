# Non-secret Docker Compose settings. Keep real secrets in AWS SSM Parameter
# Store and materialize them as root-readable files with vps-deploy.sh.
COMPOSE_PROJECT_NAME=crowdquest
CROWDQUEST_IMAGE_TAG=local
CROWDQUEST_LOOPBACK_PORT=18080

# The public HTTPS origin served by the host Caddy instance.
PUBLIC_ORIGIN=https://crowdquest.example.invalid
# Keep the legacy origin during a controlled hostname migration.
CORS_ORIGINS=https://crowdquest.example.invalid,https://legacy.example.invalid
NEXT_PUBLIC_POLAR_CHECKOUT_URL=

LOG_LEVEL=info
POSTGRES_DB=crowdquest
POSTGRES_USER=crowdquest_app
SESSION_TTL_HOURS=24
SESSION_CLEANUP_MINUTES=60
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
SESSION_CREATE_RATE_LIMIT_MAX=12
ANSWER_WINDOW_SECONDS=24

# Local encrypted-format pg_dump retention. Set an S3 URI for optional off-host copies.
CROWDQUEST_BACKUP_RETENTION_DAYS=14
CROWDQUEST_BACKUP_S3_URI=

# These files are created by deploy/vps-deploy.sh and must not be committed.
POSTGRES_PASSWORD_FILE=/var/lib/crowdquest/secrets/postgres_password
TXLINE_API_TOKEN_FILE=/var/lib/crowdquest/secrets/txline_api_token
COINBASE_AGENT_TOKEN_FILE=/var/lib/crowdquest/secrets/coinbase_agent_token
ADMIN_TOKEN_FILE=/var/lib/crowdquest/secrets/admin_token

# SSM Parameter Store names. TxLINE and Coinbase are intentionally optional so
# a transparent replay deployment can boot before those integrations activate.
SSM_POSTGRES_PASSWORD_PARAM=/crowdquest/production/postgres-password
SSM_ADMIN_TOKEN_PARAM=/crowdquest/production/admin-token
SSM_TXLINE_API_TOKEN_PARAM=
SSM_COINBASE_AGENT_TOKEN_PARAM=

TXLINE_ORIGIN=https://txline-dev.txodds.com
TXLINE_FIXTURE_ID=18209181
COINBASE_AGENT_URL=

# Production-safe default: create an approval intent; never sign automatically.
PAYOUT_MODE=approval
MAX_PAYOUT_USDC=20
