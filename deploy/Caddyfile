{
	admin off
	auto_https off
}

:8080 {
	encode zstd gzip

	log {
		output stdout
		format json
	}

	header {
		-Server
		Content-Security-Policy "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self'; form-action 'self'; frame-ancestors 'none'; img-src 'self' data:; media-src 'self'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; upgrade-insecure-requests"
		Cross-Origin-Opener-Policy "same-origin"
		Cross-Origin-Resource-Policy "same-origin"
	}

	@demo path /demo.mp4
	header @demo >Content-Type "video/mp4"

	@api path /healthz /v1 /v1/*
	handle @api {
		reverse_proxy orchestrator:8788 {
			health_uri /healthz
			health_interval 30s
			health_timeout 5s
		}
	}

	handle {
		reverse_proxy web:3000 {
			health_uri /
			health_interval 30s
			health_timeout 5s
		}
	}
}
